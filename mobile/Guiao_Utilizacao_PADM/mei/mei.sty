% ===== Alunos (múltiplos) =====
% listas internas (nomes e números)
\def\students{}
\def\nralunos{}

% adiciona um aluno: \student{Nome}{Numero}
\newcommand{\student}[2]{%
  \ifx\students\empty
    \def\students{#1}%
    \def\nralunos{#2}%
  \else
    \edef\students{\students, #1}%
    \edef\nralunos{\nralunos, #2}%
  \fi
}

