    <!-- ── Help Desk ─────────────────────────────────────────────── -->
    <string name="helpdesk_hero_title">We\'re here to help you</string>
    <string name="helpdesk_hero_subtitle">Browse our frequently asked questions or search for a specific topic below.</string>
    <string name="helpdesk_search_hint">Search questions…</string>
    <string name="helpdesk_faq_title">Frequently Asked Questions</string>
    <string name="helpdesk_no_results">No results for "%1$s"</string>
