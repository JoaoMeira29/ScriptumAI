# ================================
# JWT
# ================================
# Gera um secret seguro: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=CHANGE_ME_generate_a_secure_random_secret

# ================================
# PostgreSQL
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass_secret
AUTH_DB_NAME=auth_db

ORG_DB_USER=organization_user
ORG_DB_PASSWORD=organization_pass_secret
ORG_DB_NAME=organization_db

DOC_DB_USER=document_user
DOC_DB_PASSWORD=document_pass_secret
DOC_DB_NAME=document_db

NOTIF_DB_USER=notification_user
NOTIF_DB_PASSWORD=notification_pass_secret
NOTIF_DB_NAME=notification_db

# ================================
# RabbitMQ
# ================================
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq

# ================================
# MinIO (Object Storage)
# ================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ================================
# SMTP — Email (desenvolvimento)
# Por defeito usa Mailpit (servidor local de email de teste)
# Para usar Gmail real: preenche SMTP_HOST, SMTP_USER e SMTP_PASS
# ================================
SMTP_FROM_EMAIL=noreply@scriptum.ai
SMTP_FROM_NAME=ScriptumAI

# ================================
# Frontend URL (para links nos emails, ex: invites)
# ================================
FRONTEND_URL=http://localhost:3000
